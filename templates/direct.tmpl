<html>
    <head>
        <style>
            {{ .Stylesheet }}
        </style>
        <title>albumd - {{ .Content.AlbumName }}</title>
    </head>
    <body>
        <header>
            <a href="/a/{{ .Content.HashedAlbumName }}">
                <span>{{ .Content.AlbumName }}</span>
            </a>
        </header>
		
        <div class="direct-container">
            <div class="direct-image">
                <img src="/original/{{ .Content.ImagePath }}" alt="{{ .Content.ImageName }}" />
            </div>
            
            {{ if .Content.Description }}
            <div class="direct-description">
                {{ .Content.Description }}
            </div>
            {{ end }}
            
            <div class="direct-navigation">
                {{ if .Content.PrevImage }}
                <a href="/traverse/{{ .Content.HashedAlbumName }}/{{ .Content.ImageName }}/prev" class="nav-button">← Previous</a>
                {{ else }}
                <span class="nav-button-disabled">← Previous</span>
                {{ end }}
                
                <a href="/a/{{ .Content.HashedAlbumName }}" class="nav-button">Back to Album</a>
                
                {{ if .Content.NextImage }}
                <a href="/traverse/{{ .Content.HashedAlbumName }}/{{ .Content.ImageName }}/next" class="nav-button">Next →</a>
                {{ else }}
                <span class="nav-button-disabled">Next →</span>
                {{ end }}
            </div>
        </div>
    </body>
</html>
